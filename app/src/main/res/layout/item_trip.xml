<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_trip"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp" app:cardElevation="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top colored section -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="120dp"
            android:id="@+id/frame_card_top">

            <!-- Gradient background set programmatically -->
            <View android:id="@+id/view_card_bg"
                android:layout_width="match_parent" android:layout_height="match_parent"/>

            <!-- Decorative circle -->
            <ImageView android:layout_width="100dp" android:layout_height="100dp"
                android:layout_gravity="end|bottom"
                android:layout_marginEnd="-20dp"
                android:layout_marginBottom="-20dp"
                android:src="@drawable/dot_white"
                android:contentDescription="@null"/>

            <!-- Emoji big -->
            <TextView android:id="@+id/tv_trip_emoji"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:layout_margin="16dp"
                android:textSize="40sp"/>

            <!-- Trip name -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/tv_trip_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="20sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView android:id="@+id/tv_trip_dates"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#CCFFFFFF"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Bottom white section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp"
            android:background="#FFFFFF" android:gravity="center_vertical">

            <!-- Destinations count -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_map_pin"
                    android:contentDescription="@null"/>

                <TextView android:id="@+id/tv_trip_dest_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#555555"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Calendar -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="@null"/>
                <TextView android:id="@+id/tv_trip_duration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#888888"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Arrow -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" ›" android:textSize="24sp" android:textColor="#FF6B35"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>