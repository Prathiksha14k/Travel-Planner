<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="#FF6B35">

    <TextView android:id="@+id/tv_splash_logo"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🌍" android:textSize="80sp"
        android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TravelMate"
        android:textColor="#FFFFFF" android:textSize="32sp"
        android:textStyle="bold"/>

    <TextView android:id="@+id/tv_splash_tagline"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Plan your perfect adventure"
        android:textColor="#CCFFFFFF" android:textSize="16sp"
        android:layout_marginTop="8dp"/>
</LinearLayout>