<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <!-- Timeline column -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Dot -->
        <View android:id="@+id/view_timeline_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_orange"
            android:layout_marginTop="18dp"/>

        <!-- Line -->
        <View android:id="@+id/view_timeline_line"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="#DDDDDD"
            android:minHeight="30dp"/>
    </LinearLayout>

    <!-- Content -->
    <com.google.android.material.card.MaterialCardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Time + Delete row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView android:id="@+id/tv_item_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#FF6B35"
                    android:textStyle="bold"/>

                <ImageButton android:id="@+id/btn_delete_item"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFAAAAAA"
                    android:contentDescription="Delete"/>
            </LinearLayout>

            <!-- Place name -->
            <TextView android:id="@+id/tv_item_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="2dp"/>

            <!-- Category badge -->
            <TextView android:id="@+id/tv_item_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>

            <!-- Notes -->
            <TextView android:id="@+id/tv_item_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#666666"
                android:background="#FFF8F5"
                android:padding="6dp"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.3"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>