<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF6B35" android:padding="16dp"
        android:orientation="horizontal" android:gravity="center_vertical">

        <ImageButton android:id="@+id/btn_back_add"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button"
            app:tint="@android:color/white"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Add Destination"
                android:textColor="#FFFFFF" android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Search or tap on map"
                android:textColor="#CCFFFFFF" android:textSize="12sp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🗺️" android:textSize="28sp"/>
    </LinearLayout>

    <!-- Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp" app:cardElevation="6dp"
        app:strokeColor="#FF6B35" app:strokeWidth="1dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="8dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="🔍 Search city, landmark, place..."
                app:boxStrokeColor="#FF6B35" app:hintTextColor="#FF6B35">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search_place"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:imeOptions="actionSearch"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView android:id="@+id/tv_searching"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔍 Searching..."
                android:textColor="#FF6B35" android:textSize="12sp"
                android:layout_marginStart="8dp" android:layout_marginTop="4dp"
                android:visibility="gone"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Search Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_results"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:maxHeight="200dp"
        android:visibility="gone"
        android:background="@android:color/white"
        android:elevation="8dp"/>

    <!-- Selected Place Banner -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp" android:layout_marginBottom="4dp"
        app:cardCornerRadius="8dp" app:cardBackgroundColor="#FFF3EE"
        app:strokeColor="#FF6B35" app:strokeWidth="1dp">
        <TextView android:id="@+id/tv_selected_place"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="12dp" android:textSize="14sp"
            android:textColor="#FF6B35" android:textStyle="bold"
            android:visibility="gone"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Map hint -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="👆 Tap anywhere on the map to select a location"
        android:textSize="12sp" android:textColor="#888888"
        android:gravity="center" android:paddingBottom="4dp"/>

    <!-- Map -->
    <WebView android:id="@+id/osm_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Confirm Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_destination"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="✅ Add This Destination"
        android:textSize="16sp" android:textStyle="bold"
        android:backgroundTint="#FF6B35"
        app:cornerRadius="28dp"/>

</LinearLayout>