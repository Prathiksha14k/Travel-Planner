<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.travel.planner">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.TravelPlanner"
        android:usesCleartextTraffic="true">

        <activity android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TravelPlanner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".activities.AddDestinationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>



        <activity android:name=".activities.MainActivity" android:exported="false"/>
        <activity android:name=".activities.CreateTripActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".activities.TripDetailActivity" android:exported="false"/>
        <activity android:name=".activities.ScheduleActivity"
            android:exported="false"/>
        <activity android:name=".activities.RecommendationsActivity"
            android:exported="false"/>

    </application>
</manifest>